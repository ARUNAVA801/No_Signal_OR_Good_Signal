 peak_wavelength = wavelength[wl]

 values = X[:, wl]

 overall_mean = np.mean(values)

 w_var = 0
 b_var = 0
 
 for cls in np.unique(labels):
      
      class_values = values[labels==cls]

      class_mean = np.mean(class_values)
 
      w_var += np.sum((class_values - class_mean)**2)  # w_var
 
      b_var += len(class_values)*((class_mean - overall_mean)**2)

      
 print("\npeak wavelength \n", peak_wavelength)
 within_var[peak_wavelength] = w_var  # as key is immutable so it is not changed
 bw_var[peak_wavelength] = b_var 
 
 score = b_var / ( w_var + 1e-8 )

 Scores[peak_wavelength] = score

 print("\nDiscriminative Score per Wavelength", Scores, "\n")
 print("Variances in Same Class \n", within_var.items(), "\n")
 print("Variances in different Classes\n",bw_var.items(), "\n")

ranking = sorted(Scores.items(), key=lambda X: X[1], reverse= True)

for wv, score in ranking:
   print(f"wavelength {wv:.2f} nm,  Score{score:.4f}")
